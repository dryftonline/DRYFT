// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  passwordHash  String
  roleId        Int
  role          Role      @relation(fields: [roleId], references: [id])
  franchiseId   Int?
  franchise     Franchise? @relation(fields: [franchiseId], references: [id])
  status        String    @default("active") // active, inactive
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  uploadedCustomers Customer[] @relation("UploadedBy")
  stockLogs     StockUpdateLog[]
  sentNotifications Notification[]
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id    Int              @id @default(autoincrement())
  name  String           @unique
  roles RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Franchise {
  id           Int       @id @default(autoincrement())
  name         String
  ownerName    String
  phoneNumber  String
  email        String
  location     String
  status       String    @default("active") // active, inactive
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  users        User[]
  customers    Customer[]
  stockItems   FranchiseStock[]
  notifications NotificationRecipient[]
}

model Customer {
  id              Int       @id @default(autoincrement())
  name            String
  phone           String
  carPhotoUrl     String?
  carRegistration String
  carModel        String
  franchiseId     Int
  franchise       Franchise @relation(fields: [franchiseId], references: [id])
  uploadedBy      Int
  uploader        User      @relation("UploadedBy", fields: [uploadedBy], references: [id])
  notes           String?
  status          String    @default("pending") // pending, completed
  created_at      DateTime  @default(now())
}

model StockItem {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  defaultQuantity Int       @default(0)
  franchiseStocks FranchiseStock[]
}

model FranchiseStock {
  id                Int       @id @default(autoincrement())
  franchiseId       Int
  franchise         Franchise @relation(fields: [franchiseId], references: [id])
  stockItemId       Int
  stockItem         StockItem @relation(fields: [stockItemId], references: [id])
  availableQuantity Int       @default(0)
  lowStockThreshold Int       @default(10)
  lastUpdatedBy     Int?
  updated_at        DateTime  @updatedAt
  logs              StockUpdateLog[]

  @@unique([franchiseId, stockItemId])
}

model StockUpdateLog {
  id               Int            @id @default(autoincrement())
  franchiseStockId Int
  franchiseStock   FranchiseStock @relation(fields: [franchiseStockId], references: [id])
  previousQuantity Int
  newQuantity      Int
  userId           Int
  user             User           @relation(fields: [userId], references: [id])
  created_at       DateTime       @default(now())
}

model Notification {
  id         Int       @id @default(autoincrement())
  title      String
  message    String
  priority   String    @default("Normal") // Normal, Important, Urgent
  targetType String    @default("All") // All, Selected
  sentBy     Int
  sender     User      @relation(fields: [sentBy], references: [id])
  created_at DateTime  @default(now())
  recipients NotificationRecipient[]
}

model NotificationRecipient {
  notificationId Int
  notification   Notification @relation(fields: [notificationId], references: [id])
  franchiseId    Int
  franchise      Franchise    @relation(fields: [franchiseId], references: [id])

  @@id([notificationId, franchiseId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  resource   String
  resourceId String?
  created_at DateTime @default(now())
}
