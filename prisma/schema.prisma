generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                Int              @id @default(autoincrement())
  username          String           @unique
  passwordHash      String
  roleId            Int
  franchiseId       Int?
  status            String           @default("active")
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  uploadedCustomers Customer[]       @relation("UploadedBy")
  sentNotifications Notification[]
  stockLogs         StockUpdateLog[]
  franchise         Franchise?       @relation(fields: [franchiseId], references: [id])
  role              Role             @relation(fields: [roleId], references: [id])
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id    Int              @id @default(autoincrement())
  name  String           @unique
  roles RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
}

model Franchise {
  id            Int                     @id @default(autoincrement())
  name          String
  ownerName     String
  phoneNumber   String
  email         String
  location      String
  status        String                  @default("active")
  created_at    DateTime                @default(now())
  updated_at    DateTime                @updatedAt
  customers     Customer[]
  stockItems    FranchiseStock[]
  notifications NotificationRecipient[]
  users         User[]
  staff         Staff[]
}

model Customer {
  id              Int       @id @default(autoincrement())
  name            String
  phone           String
  carPhotoUrl     String?
  carRegistration String
  carModel        String
  franchiseId     Int
  uploadedBy      Int
  notes           String?
  status          String    @default("ongoing")
  kot             String?
  service         String?
  vehicleType     String?
  addon           String?
  addonAmount     Float?
  discountType    String?
  discount        Float?
  discountNote    String?
  finalTotal      Float?
  paymentMethod   String?
  created_at      DateTime  @default(now())
  franchise       Franchise @relation(fields: [franchiseId], references: [id])
  uploader        User      @relation("UploadedBy", fields: [uploadedBy], references: [id])
  staffId         Int?
  staff           Staff?    @relation("StaffJobs", fields: [staffId], references: [id])
}

model StockItem {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  defaultQuantity Int              @default(0)
  franchiseStocks FranchiseStock[]
}

model FranchiseStock {
  id                Int              @id @default(autoincrement())
  franchiseId       Int
  stockItemId       Int
  availableQuantity Int              @default(0)
  lowStockThreshold Int              @default(10)
  lastUpdatedBy     Int?
  updated_at        DateTime         @updatedAt
  franchise         Franchise        @relation(fields: [franchiseId], references: [id])
  stockItem         StockItem        @relation(fields: [stockItemId], references: [id])
  logs              StockUpdateLog[]

  @@unique([franchiseId, stockItemId])
}

model StockUpdateLog {
  id               Int            @id @default(autoincrement())
  franchiseStockId Int
  previousQuantity Int
  newQuantity      Int
  userId           Int
  created_at       DateTime       @default(now())
  franchiseStock   FranchiseStock @relation(fields: [franchiseStockId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
}

model Notification {
  id         Int                     @id @default(autoincrement())
  title      String
  message    String
  priority   String                  @default("Normal")
  targetType String                  @default("All")
  sentBy     Int
  created_at DateTime                @default(now())
  sender     User                    @relation(fields: [sentBy], references: [id])
  recipients NotificationRecipient[]
}

model NotificationRecipient {
  notificationId Int
  franchiseId    Int
  franchise      Franchise    @relation(fields: [franchiseId], references: [id])
  notification   Notification @relation(fields: [notificationId], references: [id])

  @@id([notificationId, franchiseId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  resource   String
  resourceId String?
  created_at DateTime @default(now())
}

model Staff {
  id          Int               @id @default(autoincrement())
  name        String
  phone       String?
  role        String            @default("Washer")
  franchiseId Int
  status      String            @default("active")
  created_at  DateTime          @default(now())
  
  franchise   Franchise         @relation(fields: [franchiseId], references: [id])
  attendances StaffAttendance[]
  jobsDone    Customer[]        @relation("StaffJobs")
}

model StaffAttendance {
  id          Int      @id @default(autoincrement())
  staffId     Int
  date        DateTime @default(now())
  status      String   // "present", "absent", "half-day", "late"
  photoData   String?  // Store base64 compressed image
  latitude    Float?
  longitude   Float?
  notes       String?
  
  staff       Staff    @relation(fields: [staffId], references: [id])
}
